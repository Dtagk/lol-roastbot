DISCORD_TOKEN=your_bot_token
DISCORD_CHANNEL_ID=123456789012345678
# Only roast these names (your premade crew). Empty = whole team.
CREW=Me,Dave,Steve
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Secret token shared between lcu_proxy.py (host) and the bot (Docker).
# Prevents anyone on the LAN from using the proxy. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
LCU_PROXY_SECRET=change_me
POLL_SECONDS=120
MIN_SHAME=10
# Optional: only if League is installed somewhere other than the default.
# The container mounts the Riot PARENT dir (stable across patches) and finds
# the lockfile under it. Override the host parent path here if non-standard:
# LEAGUE_PARENT_DIR=D:/Games/Riot Games
#
# Advanced: pin an exact lockfile path inside the container (skips the finder).
# LCU_LOCKFILE=/riot/League of Legends/lockfile
